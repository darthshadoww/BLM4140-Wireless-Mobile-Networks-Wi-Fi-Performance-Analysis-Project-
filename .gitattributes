# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly set text files
*.py text eol=lf
*.sh text eol=lf
*.cc text eol=lf
*.h text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Denote all files that are truly binary and should not be modified
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
